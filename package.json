{
	"name": "obsidian-annotation",
	"version": "0.1.0",
	"description": "Document-first visual annotation plugin for Obsidian.",
	"main": "main.js",
	"packageManager": "bun@1.3.14",
	"type": "module",
	"scripts": {
		"dev": "bun scripts/build.ts",
		"build": "bun run tsc && bun scripts/build.ts --prod",
		"build:excalidraw": "yarn --cwd ./excalidraw install --frozen-lockfile && yarn --cwd ./excalidraw build:packages && yarn --cwd ./excalidraw/packages/utils build:esm",
		"build:with-excalidraw": "bun run build:excalidraw && bun run build",
		"tsc": "tsc --noEmit",
		"tsc:watch": "tsc --noEmit --watch --preserveWatchOutput",
		"tscw": "bun run tsc:watch",
		"lint": "biome lint --diagnostic-level=error .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"test": "bun -e 'console.log(\"No tests configured.\")'",
		"release": "./scripts/release.sh",
		"validate": "bun run --parallel tsc test lint"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"annotation"
	],
	"license": "MIT",
	"devDependencies": {
		"@tailwindcss/cli": "4.1.17",
		"@types/bun": "latest",
		"@biomejs/biome": "^2.3.7",
		"obsidian": "latest",
		"tailwindcss": "4.1.17",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@excalidraw/common": "file:excalidraw/packages/common",
		"@excalidraw/element": "file:excalidraw/packages/element",
		"@excalidraw/excalidraw": "file:excalidraw/packages/excalidraw",
		"@excalidraw/fractional-indexing": "file:excalidraw/packages/fractional-indexing",
		"@excalidraw/math": "file:excalidraw/packages/math",
		"perfect-freehand": "^1.2.3",
		"roughjs": "^4.6.6"
	},
	"overrides": {
		"@excalidraw/common": "file:excalidraw/packages/common",
		"@excalidraw/element": "file:excalidraw/packages/element",
		"@excalidraw/excalidraw": "file:excalidraw/packages/excalidraw",
		"@excalidraw/fractional-indexing": "file:excalidraw/packages/fractional-indexing",
		"@excalidraw/math": "file:excalidraw/packages/math"
	}
}
